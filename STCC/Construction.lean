omit CW in theorem char_cnp1_boundary_in_skn (n: ‚Ąē): ‚ąÄ e: CellOfDim (n + 1), ‚ąÄ x: (cb (n + 1)), x ‚ąą cb_boundary ‚Üí (characteristic_cn (n + 1) e x) ‚ąą Skeleton X n := by
  rintro ‚ü®e, he‚ü© x x_in_boundary
  have mem_0: characteristic_cn (n + 1) ‚ü®e, he‚ü© x ‚ąą Set.range (cb_boundary_map (C.characteristic_map e)) := by
    rw [characteristic_cn]
    apply mem_boundary_map_range_of_mem_boundary
    apply @Eq.rec ‚Ąē (n + 1) (fun (n':‚Ąē) (eq:(n + 1 = n')) ‚Ü¶ (congrArg (fun p ‚Ü¶ (cb p:Type)) eq.symm).mpr x ‚ąą @cb_boundary n') x_in_boundary _ (he.symm)
  have mem_1: Set.range (cb_boundary_map (C.characteristic_map e)) ‚äÜ ‚čÉp:sets, ‚čÉ_:(C.dim_map p < C.dim_map e), p.1 := C.characteristic_map_boundary e
  have mem_2: ‚čÉp:sets, ‚čÉ_:(C.dim_map p < C.dim_map e), p.1 ‚äÜ Skeleton X n := by
    rw [Set.iUnion‚āā_subset_iff]
    intro p hp
    rw [he] at hp
    rw [sub_skeleton_iff, Nat.le_iff_lt_add_one]
    exact hp
  exact mem_2 (mem_1 mem_0)

def skn_sum_cnp1_to_sknp1 (n: ‚Ąē): (Skeleton X n) ‚äē (ő£_:@CellOfDim X _ _ C (n + 1), cb (n + 1)) ‚Üí (Skeleton X (n + 1)) := by
  intro x
  match x with
  | Sum.inl ‚ü®x, x_in_Xn‚ü© =>
    exact ‚ü®x, skeleton_mono n (n + 1) (Nat.le_add_right n 1) x_in_Xn‚ü©
  | Sum.inr ‚ü®‚ü®e, he‚ü©, x‚ü© =>
    use C.characteristic_map e ((congrArg (fun p ‚Ü¶ (cb p : Type)) he).mpr x)
    suffices Set.range (C.characteristic_map e) ‚äÜ (Skeleton X (n + 1)) by exact this (Set.mem_range_self _)
    rw [characteristic_map_range]
    apply (Skeleton X (n + 1)).cell_closure_incl e.1 e.2
    show e.1 ‚äÜ Skeleton X (n + 1)
    rw [sub_skeleton_iff, he]

omit CW in theorem skn_sum_cnp1_to_sknp1_surj {n: ‚Ąē}: Function.Surjective (skn_sum_cnp1_to_sknp1 (C := C) n) := by
  intro x
  rcases exists_mem_of_cell (x:X) with ‚ü®e, e_in_sets, x_in_e‚ü©
  have : C.dim_map ‚ü®e, e_in_sets‚ü© ‚Č§ (n + 1) := by
    rw [‚Üźsub_skeleton_iff]
    simp
    apply (Skeleton X (n + 1)).subset_of_intersect e_in_sets
    rw [‚ÜźSet.nonempty_iff_ne_empty]
    use x
    exact ‚ü®x_in_e, x.2‚ü©
  match Nat.le_succ_iff.mp this with
  | Or.inl dim_e_le_n =>
    have: (x:X) ‚ąą (Skeleton X n) := by
      suffices e ‚äÜ (Skeleton X n) by
        exact this x_in_e
      show (‚ü®e, e_in_sets‚ü©:C.sets).1 ‚äÜ (Skeleton X n)
      rwa [sub_skeleton_iff]
    use Sum.inl ‚ü®x, this‚ü©
    rfl
  | Or.inr dim_e_eq_np1 =>
    let e': C.sets := ‚ü®e, e_in_sets‚ü©
    have : (x:X) ‚ąą e'.1 := x_in_e
    rw [‚Üźcharacteristic_map_inner_image] at this
    rcases this with ‚ü®y, y_in_inner, y_map_to_x‚ü©
    let f := (congrArg (fun p ‚Ü¶ (cb p: Type)) dim_e_eq_np1).mp
    let g := (congrArg (fun p ‚Ü¶ (cb p: Type)) dim_e_eq_np1).mpr
    let y': cb (n + 1) := (congrArg (fun p ‚Ü¶ (cb p: Type)) dim_e_eq_np1).mp y
    use Sum.inr ‚ü®‚ü®e', dim_e_eq_np1‚ü©, y'‚ü©
    simp [skn_sum_cnp1_to_sknp1]
    apply SetCoe.ext;simp
    show C.characteristic_map e' (g y') = x
    have : g (f y) = y := by simp [f, g]
    rwa [this]

omit CW in theorem skn_sum_cnp1_to_sknp1_cont {n: ‚Ąē}: Continuous (skn_sum_cnp1_to_sknp1 (C:= C) n) := by
  rw [continuous_sum_dom]
  refine And.intro ?inl_cont ?inr_cont
  case inl_cont =>
    have : skn_sum_cnp1_to_sknp1 n ‚ąė Sum.inl = fun x ‚Ü¶ ‚ü®x.1, skeleton_mono (C:=C) n (n + 1) (Nat.le_add_right n 1) x.2‚ü© := by
      ext x
      simp [skn_sum_cnp1_to_sknp1]
    rw [this]
    exact Continuous.subtype_mk continuous_subtype_val fun x ‚Ü¶ skeleton_mono n (n + 1) (Nat.le_add_right n 1) x.property
  case inr_cont =>
    apply continuous_sigma
    intro e
    simp [skn_sum_cnp1_to_sknp1]
    apply Continuous.subtype_mk
    apply Continuous.comp
    . apply C.characteristic_map_continuous
    exact @Eq.rec ‚Ąē (C.dim_map e.1) (fun n hn ‚Ü¶ Continuous (congrArg (fun p ‚Ü¶ (cb p : Type)) hn).mpr) (continuous_id) (n + 1) e.2

omit CW in theorem skn_sum_cnp1_to_sknp1_factors {n: ‚Ąē}: ‚ąÄ x‚āĀ x‚āā: (Skeleton X n) ‚äē (ő£_:CellOfDim (n + 1), cb (n + 1)),
  glue_setoid
    (@CellAttached_boundary (n + 1) (CellOfDim (n + 1)))
    (@CellAttached_f X (n + 1) (CellOfDim (n + 1)) (Skeleton X n) (characteristic_cn (n + 1)) (char_cnp1_boundary_in_skn n))
    x‚āĀ x‚āā ‚Üí
  skn_sum_cnp1_to_sknp1 n x‚āĀ = skn_sum_cnp1_to_sknp1 n x‚āā := by
    intro x‚āĀ x‚āā h‚āĀ‚āā
    rcases glue_rel_equiv_explicit _ _ x‚āĀ x‚āā h‚āĀ‚āā with c0 | c1 | c2 | c3 | c4
    . rcases c0 with ‚ü®x, heq1, heq2‚ü©
      rw [heq2]
    . rcases c1 with ‚ü®x, y, y', heq1, heq2, heq3, heq4‚ü©
      rw [CellAttached_f] at heq4
      simp [heq1, skn_sum_cnp1_to_sknp1, heq2, heq4, ‚Üźheq3, characteristic_cn]
      rw [‚Üźheq3]
    . rcases c2 with ‚ü®y, x, y', heq1, heq2, heq3, heq4‚ü©
      rw [CellAttached_f] at heq4
      simp [heq1, skn_sum_cnp1_to_sknp1, heq2, heq4, ‚Üźheq3, characteristic_cn]
      rw [‚Üźheq3]
    . rcases c3 with ‚ü®y‚āĀ, y‚āā, y‚āĀ', y‚āā', heq1, heq2, heq3, heq4, heq5, hne‚ü©
      simp [heq1, heq2, skn_sum_cnp1_to_sknp1]
      simp [CellAttached_f, characteristic_cn, heq3, heq4] at heq5
      rwa [heq3, heq4] at heq5
    . rcases c4 with ‚ü®y, heq1, heq2‚ü©
      rw [heq2]

def cell_attached_to_sknp1 (n: ‚Ąē): @CellAttached X (n + 1) _ _ (characteristic_cn (n + 1)) (char_cnp1_boundary_in_skn n) ‚Üí (Skeleton X (n + 1)) := (Quotient.lift (skn_sum_cnp1_to_sknp1 n) skn_sum_cnp1_to_sknp1_factors)

section helper
variable {X: Type*} [T: TopologicalSpace X] [T2Space X] [C: CellComplexClass X]
theorem mem_boundary_of_same_char_image‚āĀ {n: ‚Ąē} {y‚āĀ y‚āā: cb (n + 1)} {e‚āĀ e‚āā: C.sets} (h_e‚āĀ_dim: C.dim_map e‚āĀ = n + 1)
    (h_e‚āā_dim: C.dim_map e‚āā = n + 1) (h_ne_y: y‚āĀ ‚Č† y‚āā) (e‚āĀ_eq_e‚āā: e‚āĀ = e‚āā)
    (h_img_eq: C.characteristic_map e‚āĀ ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim.symm).mp y‚āĀ) =
        C.characteristic_map e‚āā ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āā_dim.symm).mp y‚āā)):
    y‚āĀ ‚ąą cb_boundary ‚ąß y‚āā ‚ąą cb_boundary := by
        have h_img_eq': C.characteristic_map e‚āĀ ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim.symm).mp y‚āĀ) =
            C.characteristic_map e‚āĀ ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim.symm).mp y‚āā) := by
                rw [h_img_eq]
                apply @Eq.rec C.sets e‚āĀ
                    (fun (e':C.sets) (h: e‚āĀ = e') ‚Ü¶
                        C.characteristic_map e' ((congrArg (fun p ‚Ü¶ (cb p:Type)) ((congrArg C.dim_map h).symm.trans h_e‚āĀ_dim).symm).mp y‚āā) =
                            C.characteristic_map e‚āĀ ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim.symm).mp y‚āā))
                    rfl
                exact e‚āĀ_eq_e‚āā
        let f : cb (n + 1) ‚Üí cb (C.dim_map e‚āĀ) := (congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim.symm).mp
        let g : cb (C.dim_map e‚āĀ) ‚Üí cb (n + 1) := (congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim).mp
        have g_f_inv: ‚ąÄ y, g (f y) = y := by
            intro y
            simp [g, f]
        have f_y_in_inner: ‚ąÄ y:(cb (n + 1)), y ‚ąą cb_inner ‚Üí f y ‚ąą cb_inner  := by
            intro y hy
            apply @Eq.rec ‚Ąē (n + 1) (fun m hm ‚Ü¶ (congrArg (fun p ‚Ü¶ (cb p : Type)) hm).mp y ‚ąą cb_inner) hy
            exact h_e‚āĀ_dim.symm
        have f_y_in_boundary: ‚ąÄy:(cb (n + 1)), y ‚ąą cb_boundary ‚Üí f y ‚ąą cb_boundary := by
            intro y hy
            apply @Eq.rec ‚Ąē (n + 1) (fun m hm ‚Ü¶ (congrArg (fun p ‚Ü¶ (cb p : Type)) hm).mp y ‚ąą cb_boundary) hy
            exact h_e‚āĀ_dim.symm
        match @cb_decomp (n + 1) y‚āĀ with
        | Or.inl y‚āĀ_in_inneer =>
            have f_y‚āĀ_in_inner : f y‚āĀ ‚ąą cb_inner := f_y_in_inner y‚āĀ y‚āĀ_in_inneer
            match @cb_decomp (n + 1) y‚āā with
            | Or.inl y‚āā_in_inner =>
                -- try to get a contradiction
                have f_y‚āā_in_inner : f y‚āā ‚ąą cb_inner := f_y_in_inner y‚āā y‚āā_in_inner
                have : y‚āĀ = y‚āā := by
                    rw [‚Üźg_f_inv y‚āĀ, ‚Üźg_f_inv y‚āā]
                    apply congrArg
                    exact characteristic_map_inj_on_inner e‚āĀ f_y‚āĀ_in_inner f_y‚āā_in_inner h_img_eq'
                contradiction
            | Or.inr y‚āā_in_boundary =>
                have f_y‚āā_in_boundary: f y‚āā ‚ąą cb_boundary := f_y_in_boundary y‚āā y‚āā_in_boundary
                have : C.characteristic_map e‚āĀ (f y‚āĀ) ‚Č† C.characteristic_map e‚āĀ (f y‚āā) := by
                    exact characteristic_map_inner_boundary_ne _ _ _ _ f_y‚āĀ_in_inner f_y‚āā_in_boundary rfl
                contradiction
        | Or.inr y‚āĀ_in_boundary =>
            have f_y‚āĀ_in_boundary: f y‚āĀ ‚ąą cb_boundary := f_y_in_boundary y‚āĀ y‚āĀ_in_boundary
            match @cb_decomp (n + 1) y‚āā with
            | Or.inl y‚āā_in_inner =>
                have f_y‚āā_in_inner: f y‚āā ‚ąą cb_inner := f_y_in_inner _ y‚āā_in_inner
                have: C.characteristic_map e‚āĀ (f y‚āĀ) ‚Č† C.characteristic_map e‚āĀ (f y‚āā) := by
                    apply Ne.symm
                    exact characteristic_map_inner_boundary_ne _ _ _ _ f_y‚āā_in_inner f_y‚āĀ_in_boundary rfl
                contradiction
            | Or.inr y‚āā_in_boundary =>
                exact ‚ü®y‚āĀ_in_boundary, y‚āā_in_boundary‚ü©

theorem mem_boundary_of_same_char_image‚āā {n: ‚Ąē} {y‚āĀ y‚āā: cb (n + 1)} {e‚āĀ e‚āā: C.sets} (h_e‚āĀ_dim: C.dim_map e‚āĀ = n + 1)
    (h_e‚āā_dim: C.dim_map e‚āā = n + 1) (e‚āĀ_ne_e‚āā: e‚āĀ ‚Č† e‚āā)
    (h_img_eq: C.characteristic_map e‚āĀ ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āĀ_dim.symm).mp y‚āĀ) =
        C.characteristic_map e‚āā ((congrArg (fun p ‚Ü¶ (cb p : Type)) h_e‚āā_dim.symm).mp y‚āā)):
    y‚āĀ ‚ąą cb_boundary ‚ąß y‚āā ‚ąą cb_boundary := by
      let ff : (e:C.sets) ‚Üí (he: C.dim_map e = n + 1) ‚Üí cb (n + 1) ‚Üí cb (C.dim_map e) := fun e he ‚Ü¶ (congrArg (fun p ‚Ü¶ (cb p : Type)) he.symm).mp
      have ff_y_in_set: ‚ąÄ e:C.sets, ‚ąÄ he: (C.dim_map e = n + 1), ‚ąÄ sf: ((n:‚Ąē) ‚Üí Set (cb n)), ‚ąÄ y:cb (n + 1), y ‚ąą sf (n + 1) ‚Üí ff e he y ‚ąą sf (C.dim_map e) := by
        intro e he sf y hy
        apply @Eq.rec ‚Ąē (n + 1) (fun m hm ‚Ü¶ (congrArg (fun p ‚Ü¶ (cb p : Type)) hm).mp y ‚ąą sf m) hy
        exact he.symm
      let y‚āĀ' := ff e‚āĀ h_e‚āĀ_dim y‚āĀ
      let y‚āā' := ff e‚āā h_e‚āā_dim y‚āā
      have h_img_eq' : C.characteristic_map e‚āĀ y‚āĀ' = C.characteristic_map e‚āā y‚āā' := h_img_eq
      match @cb_decomp (n + 1) y‚āĀ with
      | Or.inl y‚āĀ_in_inner =>
        have ff_y‚āĀ_in_inner : y‚āĀ' ‚ąą cb_inner := ff_y_in_set e‚āĀ h_e‚āĀ_dim @cb_inner y‚āĀ y‚āĀ_in_inner
        have cff_y‚āĀ_in_e‚āĀ: C.characteristic_map e‚āĀ y‚āĀ' ‚ąą e‚āĀ.1 := by rw [‚Üźcharacteristic_map_inner_image];use y‚āĀ'
        match @cb_decomp (n + 1) y‚āā with
        | Or.inl y‚āā_in_inner =>
          have f_y‚āā_in_inner : y‚āā' ‚ąą cb_inner := ff_y_in_set e‚āā h_e‚āā_dim @cb_inner y‚āā y‚āā_in_inner
          have cff_y‚āā_in_e‚āā: C.characteristic_map e‚āā y‚āā' ‚ąą e‚āā.1 := by rw [‚Üźcharacteristic_map_inner_image];use y‚āā'
          rw [‚Üźh_img_eq] at cff_y‚āā_in_e‚āā
          have : e‚āĀ = e‚āā := by
            apply SetCoe.ext
            exact same_cell_of_mem e‚āĀ.2 e‚āā.2 cff_y‚āĀ_in_e‚āĀ cff_y‚āā_in_e‚āā
          contradiction
        | Or.inr y‚āā_in_boundary =>
          have ff_y‚āā_in_boundary : y‚āā' ‚ąą cb_boundary := ff_y_in_set e‚āā h_e‚āā_dim @cb_boundary y‚āā y‚āā_in_boundary
          have : C.characteristic_map e‚āĀ y‚āĀ' ‚Č† C.characteristic_map e‚āā y‚āā' := characteristic_map_inner_boundary_ne e‚āĀ e‚āā y‚āĀ' y‚āā' ff_y‚āĀ_in_inner ff_y‚āā_in_boundary (h_e‚āĀ_dim.trans h_e‚āā_dim.symm)
          contradiction
      | Or.inr y‚āĀ_in_boundary =>
        have ff_y‚āĀ_in_boundary : y‚āĀ' ‚ąą cb_boundary := ff_y_in_set e‚āĀ h_e‚āĀ_dim @cb_boundary y‚āĀ y‚āĀ_in_boundary
        match @cb_decomp (n + 1) y‚āā with
        | Or.inl y‚āā_in_inner =>
          have ff_y‚āā_in_inner : y‚āā' ‚ąą cb_inner := ff_y_in_set e‚āā h_e‚āā_dim @cb_inner y‚āā y‚āā_in_inner
          have : C.characteristic_map e‚āĀ y‚āĀ' ‚Č† C.characteristic_map e‚āā y‚āā' := (characteristic_map_inner_boundary_ne e‚āā e‚āĀ y‚āā' y‚āĀ' ff_y‚āā_in_inner ff_y‚āĀ_in_boundary (h_e‚āā_dim.trans h_e‚āĀ_dim.symm)).symm
          contradiction
        | Or.inr y‚āā_in_boundary =>
          exact ‚ü®y‚āĀ_in_boundary, y‚āā_in_boundary‚ü©
end helper

theorem cell_attached_to_sknp1_homeomorphic {n: ‚Ąē} : IsHomeomorph (@cell_attached_to_sknp1 X _ _ _ n) := by
  refine quotient_lift_is_homeomorph _ ?factors ?is_quot
  case factors =>
    intro x‚āĀ x‚āā hx‚āĀx‚āā
    match x‚āĀ with
    | Sum.inl xl‚āĀ =>
      match x‚āā with
      | Sum.inl xl‚āā =>
        simp [skn_sum_cnp1_to_sknp1] at hx‚āĀx‚āā
        rw [hx‚āĀx‚āā]
      | Sum.inr xr‚āā =>
        simp [skn_sum_cnp1_to_sknp1] at hx‚āĀx‚āā
        have : xr‚āā ‚ąą CellAttached_boundary := by
          apply @mem_boundary_of_image_in_skeleton X _ _ _ n xr‚āā.2 xr‚āā.1
          case hy => simp [‚Üźhx‚āĀx‚āā]
          case h_e_dim => exact xr‚āā.1.2
        simp [glue_setoid]
        apply Relation.EqvGen.rel
        rw [glue_rel]
        use ‚ü®xr‚āā, this‚ü©
        simp [CellAttached_f, characteristic_cn, ‚Üźhx‚āĀx‚āā]
    | Sum.inr xr‚āĀ =>
      match x‚āā with
      | Sum.inl xl‚āā =>
        simp [skn_sum_cnp1_to_sknp1] at hx‚āĀx‚āā
        simp [glue_setoid]
        apply Relation.EqvGen.symm
        apply Relation.EqvGen.rel
        rw [glue_rel]
        have: xr‚āĀ ‚ąą CellAttached_boundary := by
          apply @mem_boundary_of_image_in_skeleton X _ _ _ n xr‚āĀ.2 xr‚āĀ.1
          case hy => simp [hx‚āĀx‚āā]
          case h_e_dim => exact xr‚āĀ.1.2
        use ‚ü®xr‚āĀ, this‚ü©
        simp [CellAttached_f, characteristic_cn, hx‚āĀx‚āā]
      | Sum.inr xr‚āā =>
        rcases eq_or_ne xr‚āĀ xr‚āā with heq | hne
        . exact Quotient.eq''.mp (congrArg Quotient.mk'' (congrArg Sum.inr heq))
        simp [skn_sum_cnp1_to_sknp1] at hx‚āĀx‚āā
        have: xr‚āĀ ‚ąą CellAttached_boundary ‚ąß xr‚āā ‚ąą CellAttached_boundary:= by
          rcases (eq_or_ne xr‚āĀ.1 xr‚āā.1) with heq' | hne'
          . have: xr‚āĀ.2 ‚Č† xr‚āā.2 := by
              contrapose! hne
              exact Sigma.subtype_ext heq' (congrArg Subtype.val hne)
            exact mem_boundary_of_same_char_image‚āĀ (C:=C) xr‚āĀ.1.2 xr‚āā.1.2 this (congrArg Subtype.val heq') hx‚āĀx‚āā
          exact mem_boundary_of_same_char_image‚āā (C:=C) xr‚āĀ.1.2 xr‚āā.1.2 (Subtype.coe_ne_coe.mpr hne') hx‚āĀx‚āā
        refine glue_setoid_of_same_image _ _ this.1 this.2 ?heq
        simpa [CellAttached_f, characteristic_cn] using hx‚āĀx‚āā
  case is_quot =>
    apply quotient_of_saturate_closed_image_closed
    case f_cont => apply skn_sum_cnp1_to_sknp1_cont
    case f_surj => apply skn_sum_cnp1_to_sknp1_surj
    intro S hS SClosed
    rw [is_closed_iff_is_closed_in_ce_less_than_dim]
    intro e h_e_dim
    match Nat.le_succ_iff.mp h_e_dim with
    | Or.inl dim_e_le_n =>
      let g‚āĀ : (Skeleton X n) ‚Üí X := (‚ÜĎ)
      let g‚āā : (Skeleton X (n + 1)) ‚Üí X := (‚ÜĎ)
      show IsClosed (closure e.1 ‚ą© g‚āā '' (skn_sum_cnp1_to_sknp1 n '' S))
      have : closure e.1 ‚ą© g‚āā '' (skn_sum_cnp1_to_sknp1 n '' S) = closure e.1 ‚ą© g‚āĀ '' (Sum.inl ‚ĀĽ¬Ļ' S) := by
        ext x
        refine Iff.intro ?mp ?mpr
        case mp =>
          intro hx
          use hx.1
          have ce_sub_Xn : closure e.1 ‚äÜ (Skeleton X n) := by
            apply (Skeleton X n).cell_closure_incl _ e.2
            show e.1 ‚äÜ (Skeleton X n)
            rwa [sub_skeleton_iff e]
          use ‚ü®x, ce_sub_Xn hx.1‚ü©
          simp [g‚āĀ]
          have: ‚ąÉ y ‚ąą S, x = g‚āā (skn_sum_cnp1_to_sknp1 n y) := by
            rcases hx.2 with ‚ü®w, hw, heq1‚ü©
            rcases hw with ‚ü®u, hu, heq2‚ü©
            rw [‚Üźheq2] at heq1
            use u, hu, heq1.symm
          rcases this with ‚ü®t, ht, htx‚ü©
          have : x = g‚āā (skn_sum_cnp1_to_sknp1 n (Sum.inl ‚ü®x, ce_sub_Xn hx.1‚ü©)) := by simp [g‚āā, skn_sum_cnp1_to_sknp1]
          rw [this] at htx
          rw [Set.ext_iff] at hS
          rw [‚ÜźhS]
          use t, ht, (Subtype.val_injective htx).symm
        case mpr =>
          sorry
      rw [this]
      have : IsClosed (Sum.inl ‚ĀĽ¬Ļ' S) := IsClosed.preimage continuous_inl SClosed
      rw [is_closed_iff_is_closed_in_ce_less_than_dim] at this
      apply this
      exact dim_e_le_n
    | Or.inr dim_e_eq_np1 =>
      sorry

end

