-- a direct proof of 5.17
theorem quotient_sigma_cb_map : Topology.IsQuotientMap (fun (‚ü®e, d‚ü©: (_:C.sets) √ó cb (C.dim_map _)) ‚Ü¶ C.characteristic_map e d) where
  surjective := by
    intro x
    simp
    rcases exists_mem_of_cell x with ‚ü®e, e_in_sets, x_in_e‚ü©
    use e, e_in_sets
    have : x ‚ąą Set.range (C.characteristic_map ‚ü®e, e_in_sets‚ü©) := by
      rw [characteristic_map_range]
      apply subset_closure
      exact x_in_e
    rw [Set.mem_range] at this
    rcases this with ‚ü®y, hy‚ü©
    use y.1, y.2
  eq_coinduced := by
    rw [TopologicalSpace.ext_iff]
    intro s
    let ŌÜ := fun (‚ü®e, d‚ü©: (_:C.sets) √ó cb (C.dim_map _)) ‚Ü¶ C.characteristic_map e d
    show @IsOpen X T s ‚ÜĒ @IsOpen X (TopologicalSpace.coinduced ŌÜ instTopologicalSpaceSigma) s
    have : @IsOpen X (TopologicalSpace.coinduced ŌÜ instTopologicalSpaceSigma) s ‚ÜĒ IsOpen (ŌÜ ‚ĀĽ¬Ļ' s) := by rfl
    rw [this, isOpen_sigma_iff]
    simp only [Set.preimage_preimage, ŌÜ]
    refine Iff.intro ?mp ?mpr
    case mp =>
      intro s_open_in_X e
      apply Continuous.isOpen_preimage ?_ s s_open_in_X
      exact characteristic_map_continuous e
    case mpr=>
      intro h
      rw [CW.coeherent.open_crit]
      rintro _ ‚ü®e, e_in_sets, rfl‚ü©
      let f : cb (C.dim_map ‚ü®e, e_in_sets‚ü©) ‚Üí (closure e) := by
        intro d
        use C.characteristic_map ‚ü®e, e_in_sets‚ü© d
        show characteristic_map ‚ü®e, e_in_sets‚ü© d ‚ąą closure (‚ü®e, e_in_sets‚ü©:C.sets).1
        rw [‚Üźcharacteristic_map_range]
        exact Set.mem_range_self d
      let g : (closure e) ‚Üí X := (‚ÜĎ)
      have f_cont: Continuous f := by
        -- this refine is generated by apply?
        refine
          Continuous.subtype_mk ?_ fun x ‚Ü¶
            id
              (Eq.mpr
                (id
                  (congrArg (fun _a ‚Ü¶ characteristic_map ‚ü®e, e_in_sets‚ü© x ‚ąą _a)
                    (Eq.symm (characteristic_map_range ‚ü®e, e_in_sets‚ü©))))
                (Set.mem_range_self x))
        exact characteristic_map_continuous ‚ü®e, e_in_sets‚ü©
      have : Topology.IsQuotientMap f := by
        apply IsClosedMap.isQuotientMap (Continuous.isClosedMap f_cont) f_cont
        rintro ‚ü®x, x_in_ce‚ü©
        simp [f]
        rw [‚Üźcharacteristic_map_range' e e_in_sets, Set.mem_range] at x_in_ce
        rcases x_in_ce with ‚ü®y, hy‚ü©
        use y.1, y.2
      rw [‚ÜźTopology.IsQuotientMap.isOpen_preimage this]
      rw [Set.preimage_preimage]
      apply h

def CellAttached_boundary {n: ‚Ąē} {őĻ: Type*} : Set (ő£_: őĻ, cb n) := {x | x.2 ‚ąą cb_boundary}

def CellAttached_f {n: ‚Ąē} {őĻ: Type*} {S: Set X} (g: őĻ ‚Üí cb n ‚Üí X) (hg: ‚ąÄ i:őĻ, ‚ąÄ x:cb n, x ‚ąą cb_boundary ‚Üí  g i x ‚ąą S) : @CellAttached_boundary n őĻ ‚Üí S := fun x ‚Ü¶ ‚ü®g x.1.1 x.1.2, hg x.1.1 x.1.2 x.2‚ü©

def CellAttached {n: ‚Ąē} {őĻ: Type*} {S: Set X} (g: őĻ ‚Üí cb n ‚Üí X) (hg: ‚ąÄ i:őĻ, ‚ąÄ x:cb n, x ‚ąą cb_boundary ‚Üí  g i x ‚ąą S) :=
  AdjointSpace CellAttached_boundary (CellAttached_f g hg)

instance {n: ‚Ąē} {őĻ: Type*} {S: Set X} (g: őĻ ‚Üí cb n ‚Üí X) (hg: ‚ąÄ i:őĻ, ‚ąÄ x:cb n, x ‚ąą cb_boundary ‚Üí  g i x ‚ąą S) : TopologicalSpace (CellAttached g hg)  := by
  rw [CellAttached]
  infer_instance

def CellOfDim (n: ‚Ąē) := {e: C.sets | C.dim_map e = n}

def characteristic_cn (n: ‚Ąē) : @CellOfDim X _ _ C n ‚Üí cb n ‚Üí X := fun ‚ü®e, he‚ü© x ‚Ü¶ C.characteristic_map e ((congrArg (fun p ‚Ü¶ (cb p: Type)) he.symm).mp x)

